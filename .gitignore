# Book content (audio + aligned EPUB) is usually copyrighted and always huge.
# Storyplay tracks book.json + pack.json + code; the actual book content stays
# local. For public-domain demos, content is fetched on the user's machine via
# tools/fetch-gutenberg.py + Storyteller alignment.
books/*/content/
books/*/manifest.json
books/*/*.epub
books/*/audio/         # LibriVox MP3s fetched on demand — too large for repo

# Personal/AI-generated packs — don't commit by default.
packs/*-personal/
packs/*-private/

# Personal pack tied to a copyrighted book — chapter JSONs describe
# specific scenes from M.R. Carey's *Echo of Worlds* and the AI-generated
# images are personal-use only.
packs/echo-of-worlds-default/characters/
packs/echo-of-worlds-default/backgrounds/
packs/echo-of-worlds-default/moments/
packs/echo-of-worlds-default/chapter*.json

# Generation cache
**/.cache/
**/*.cache.json

# Python
__pycache__/
*.pyc
.venv/

# OS
.DS_Store
Thumbs.db

# Editor / agent state
.vscode/
.idea/
.claude/

# Built pack archives — produce on demand
dist/
*.spk
